{
  "name": "setup-specmatic",
  "version": "1.7.4",
  "private": true,
  "description": "Setup specmatic action",
  "homepage": "https://github.com/marketplace/actions/setup-specmatic-environment",
  "bugs": {
    "url": "https://github.com/airslate-oss/setup-specmatic/issues"
  },
  "type": "module",
  "main": "lib/setup-specmatic.js",
  "scripts": {
    "build": "tsc && esbuild lib/setup-specmatic.js --bundle --platform=node --target=node20 --format=esm --outfile=dist/setup/index.js --banner:js=\"import{createRequire as __cjsRequire}from'node:module';const require=__cjsRequire(import.meta.url);\"",
    "format": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.cjs --write \"**/*.{ts,yml,yaml}\"",
    "format-check": "prettier --no-error-on-unmatched-pattern --config ./.prettierrc.cjs --check \"**/*.{ts,yml,yaml}\"",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test": "jest --coverage",
    "all": "npm run format && npm run lint:fix && npm run build && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/airslate-oss/setup-specmatic.git"
  },
  "keywords": [
    "actions",
    "specmatic",
    "setup"
  ],
  "author": "airSlate, Inc.",
  "license": "Apache-2.0",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/http-client": "^4.0.1",
    "@actions/io": "^3.0.2",
    "@actions/tool-cache": "^4.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/semver": "^7.7.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.55.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.2",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "jest-circus": "^30.2.0",
    "nock": "^14.0.13",
    "prettier": "^3.8.3",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  }
}
